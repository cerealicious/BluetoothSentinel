<Window x:Class="BluetoothSentinel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bluetooth Sentinel" Height="500" Width="600"
        WindowStartupLocation="CenterScreen"
        Icon="Assets/app.ico">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="Refresh Devices" Click="RefreshDevices_Click"/>
            <Button Content="Pair New Device" Click="PairDevice_Click"/>
            <Button Content="About" Click="ShowAbout_Click"/>
        </StackPanel>

        <ListView x:Name="DeviceList" Grid.Row="1" Margin="0,10">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Device Name" DisplayMemberBinding="{Binding Name}" Width="200"/>
                    <GridViewColumn Header="Status" DisplayMemberBinding="{Binding StatusText}" Width="100"/>
                    <GridViewColumn Header="Auto-Connect" Width="100">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding AutoConnect, Mode=TwoWay}" 
                                          Checked="AutoConnect_Changed" 
                                          Unchecked="AutoConnect_Changed"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Action" Width="100">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Disconnect" Click="Disconnect_Click" 
                                        Tag="{Binding Id}" 
                                        Visibility="{Binding CanDisconnect}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <TextBlock Grid.Row="2" Text="Managed by cerealicios" HorizontalAlignment="Right" Foreground="Gray"/>
    </Grid>
</Window>
